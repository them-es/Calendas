	"prettier": "@wordpress/prettier-config",
	"scripts": {
		"create-languagefile": "wp i18n make-pot . languages/calendas.pot --exclude=assets,blocks/node_modules,node_modules,vendor --headers='{\"Report-Msgid-Bugs-To\":\"https://github.com/them-es/calendas/issues\"}'",
